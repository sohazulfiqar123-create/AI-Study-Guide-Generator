      ]
    },
    {
      "parameters": {
        "operation": "completion",
        "respondWith": "showText",
        "responseText": "=<div style=\"max-width:800px;margin:0 auto;padding:24px;font-family:sans-serif;line-height:1.6;text-align:left;\">{{ $json.html }}</div>"
      },
      "id": "30bc1c49-2b54-4e27-b15b-eb508c23eafe",
      "name": "Show Study Guide",
      "type": "n8n-nodes-base.form",
      "typeVersion": 2.5,
